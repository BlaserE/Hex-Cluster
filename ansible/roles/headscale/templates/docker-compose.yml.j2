# {{ ansible_managed }}

services:
  headscale:
    image: headscale/headscale:{{ headscale_version }}
    container_name: headscale
    restart: unless-stopped
    command: serve
    read_only: true
    tmpfs:
      - /var/run/headscale
    volumes:
      - {{ headscale_data_dir }}/config:/etc/headscale:ro
      - {{ headscale_data_dir }}/lib:/var/lib/headscale
    ports:
      - "127.0.0.1:{{ headscale_http_port }}:8080"
      - "0.0.0.0:{{ headscale_derp_stun_port }}:3478/udp"
    healthcheck:
      test: ["CMD", "headscale", "health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s