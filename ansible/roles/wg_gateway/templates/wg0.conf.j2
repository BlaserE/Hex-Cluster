# {{ ansible_managed }}
# /etc/wireguard/{{ wg_interface }}.conf

[Interface]
Address    = {{ wg_vps_address }}
ListenPort = {{ wg_listen_port }}
PrivateKey = {{ vault_wg_vps_private_key }}

# Home gateway peer.
# No Endpoint here — the home gateway initiates and the VPS learns
# the source address from the first incoming handshake.
# PersistentKeepalive lives on the home gateway side, not here.
[Peer]
PublicKey  = {{ vault_wg_home_public_key }}
AllowedIPs = {{ vault_wg_home_address }}/32
